@startuml
left to right direction
skinparam linetype ortho
skinparam nodesep 20
skinparam ranksep 40
skinparam dpi 150

' Linien / Pfeile schwarz
skinparam ArrowColor Black
skinparam ArrowThickness 1
skinparam BorderColor Black

' Hellblaues Farbschema für Packages, Use-Cases weiß lassen
skinparam packageBackgroundColor #DCEEFF
skinparam packageBorderColor #A6C8E8
skinparam usecaseBackgroundColor White
skinparam usecaseBorderColor #A6C8E8
skinparam actorBorderColor Black
skinparam actorBackgroundColor White

' Akteure (Aliase)
actor User as A_User
actor EMPLOYEE as A_Employee
actor CHEF as A_Chef

' Spezialisierungen
A_User <|-- A_Employee
A_User <|-- A_Chef

' Systemgrenze als Package
package "CRM System" {
  package "Authentifizierung" {
    usecase "Authentifizieren" as UC_Authentifizieren
    usecase "Login" as UC_Login
    usecase "Logout" as UC_Logout
  }

  package "Start / Dashboard" {
    usecase "Startoberfläche nutzen" as UC_Start
    usecase "Letzte Bestellungen anzeigen" as UC_LetzteBestellungen
    usecase "Letzte Kontakte anzeigen" as UC_LetzteKontakte
  }

  package "Kundenverwaltung" {
    usecase "Kunden suchen" as UC_KundenSuchen
    usecase "Kunden-Detail nutzen" as UC_KundenDetail
    usecase "Kontakt erfassen" as UC_KontaktErfassen
  }

  package "Bestellungen" {
    usecase "Bestellungen anzeigen" as UC_BestellungenAnzeigen
    usecase "Bestellungen suchen" as UC_BestellungenSuchen
  }

  package "Kontakte" {
    usecase "Kontakte anzeigen" as UC_KontakteAnzeigen
    usecase "Kontakte filtern" as UC_KontakteFiltern
  }

  package "Umsatz" {
    usecase "Umsatz anzeigen" as UC_UmsatzAnzeigen
    usecase "Umsatz gesamt anzeigen" as UC_UmsatzGesamt
    usecase "Umsatz letztes Jahr anzeigen" as UC_UmsatzLetztesJahr
    usecase "Umsatz nach Datumsbereich filtern" as UC_UmsatzFilter
  }

  package "CSV" {
    usecase "CSV verwalten" as UC_CSVVerwalten
    usecase "CSV Export" as UC_CSVExport
    usecase "CSV Import" as UC_CSVImport
  }
}

' Akteur -> Use Cases
A_User --> UC_Authentifizieren
A_User --> UC_Start
A_User --> UC_KundenDetail

A_Chef --> UC_CSVVerwalten

' Use-Case Beziehungen (include)
UC_Authentifizieren ..> UC_Login : <<include>>
UC_Authentifizieren ..> UC_Logout : <<include>>

UC_Start ..> UC_LetzteBestellungen : <<include>>
UC_Start ..> UC_LetzteKontakte : <<include>>

UC_KundenSuchen ..> UC_KundenDetail : <<include>>
UC_KundenDetail ..> UC_KontaktErfassen : <<include>>

UC_BestellungenAnzeigen ..> UC_BestellungenSuchen : <<include>>
UC_KontakteAnzeigen ..> UC_KontakteFiltern : <<include>>

UC_CSVVerwalten ..> UC_CSVExport : <<include>>
UC_CSVVerwalten ..> UC_CSVImport : <<include>>

UC_UmsatzAnzeigen ..> UC_UmsatzGesamt : <<include>>
UC_UmsatzAnzeigen ..> UC_UmsatzLetztesJahr : <<include>>
UC_UmsatzAnzeigen ..> UC_UmsatzFilter : <<include>>

@enduml